---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const poules = [
  {
    name: 'Poule Terre', accent: '#C9A84C', logo: '/assets/poules/poule_terre.png',
    teams: [
      { name: 'Équipe 1', logo: '/assets/teams/poule_terre_equipe1.png' },
      { name: 'Équipe 2', logo: '/assets/teams/poule_terre_equipe2.png' },
      { name: 'Équipe 3', logo: '/assets/teams/poule_terre_equipe3.png' },
      { name: 'Équipe 4', logo: '/assets/teams/poule_terre_equipe4.png' },
      { name: 'Équipe 5', logo: '/assets/teams/poule_terre_equipe5.png' },
    ],
  },
  {
    name: 'Poule Air', accent: '#7EB8F7', logo: '/assets/poules/poule_air.png',
    teams: [
      { name: 'Équipe 1', logo: '/assets/teams/poule_air_equipe1.png' },
      { name: 'Équipe 2', logo: '/assets/teams/poule_air_equipe2.png' },
      { name: 'Équipe 3', logo: '/assets/teams/poule_air_equipe3.png' },
      { name: 'Équipe 4', logo: '/assets/teams/poule_air_equipe4.png' },
      { name: 'Équipe 5', logo: '/assets/teams/poule_air_equipe5.png' },
    ],
  },
  {
    name: 'Poule Eau', accent: '#4ECDC4', logo: '/assets/poules/poule_eau.png',
    teams: [
      { name: 'Équipe 1', logo: '/assets/teams/poule_eau_equipe1.png' },
      { name: 'Équipe 2', logo: '/assets/teams/poule_eau_equipe2.png' },
      { name: 'Équipe 3', logo: '/assets/teams/poule_eau_equipe3.png' },
      { name: 'Équipe 4', logo: '/assets/teams/poule_eau_equipe4.png' },
      { name: 'Équipe 5', logo: '/assets/teams/poule_eau_equipe5.png' },
    ],
  },
];
---

<Layout title="Équipes — The 5 Cup">
  <Header />
  <main>
    <section class="teams-hero">
      <div class="teams-inner">
        <span class="eyebrow">The 5 Cup 2026</span>
        <h1 class="teams-title">Les <span class="gold">Équipes</span></h1>
        <p class="teams-desc">15 équipes, 3 poules élémentaires, 90 joueurs prêts à en découdre.</p>
      </div>
    </section>

    <section class="teams-content">
      <div class="teams-content-inner">
        {poules.map(poule => (
          <div class="poule-block">
            <div class="poule-header" style={`border-color: ${poule.accent}`}>
              <img src={poule.logo} alt={poule.name} class="poule-logo" />
              <h2 style={`color: ${poule.accent}`}>{poule.name}</h2>
            </div>
            <div class="poule-teams-grid">
              {poule.teams.map(team => (
                <div class="team-card">
                  <img src={team.logo} alt={team.name} class="team-card-logo" loading="lazy" />
                  <span class="team-card-name">{team.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .teams-hero {
    background: var(--bottle);
    padding: 160px 40px 100px;
  }
  .teams-inner { max-width: 1200px; margin: 0 auto; }
  .eyebrow {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.4);
    margin-bottom: 20px;
  }
  .teams-title {
    font-size: clamp(3rem, 10vw, 7rem);
    line-height: 0.9;
    color: var(--cream);
    margin-bottom: 20px;
  }
  .gold { color: var(--gold); }
  .teams-desc {
    font-size: 1rem;
    color: rgba(245,240,232,0.6);
    max-width: 500px;
  }
  .teams-content {
    background: #0f0f0f;
    padding: 80px 40px;
  }
  .teams-content-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 60px;
  }
  .poule-header {
    display: flex;
    align-items: center;
    gap: 16px;
    border-left: 3px solid;
    padding-left: 20px;
    margin-bottom: 32px;
  }
  .poule-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 8px;
  }
  .poule-header h2 { font-size: 1.5rem; }
  .poule-teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 16px;
  }
  .team-card {
    background: #141414;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: transform 0.2s, background 0.2s;
  }
  .team-card:hover {
    transform: translateY(-4px);
    background: #1a1a1a;
  }
  .team-card-logo {
    width: 64px;
    height: 64px;
    object-fit: contain;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    padding: 6px;
  }
  .team-card-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--cream);
    text-align: center;
  }
  @media (max-width: 768px) {
    .teams-hero { padding: 140px 24px 80px; }
    .teams-content { padding: 60px 24px; }
  }
</style>
