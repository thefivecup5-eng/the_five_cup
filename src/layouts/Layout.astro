---
export interface Props {
  title?: string;
  description?: string;
}
const { title = 'The 5 Cup', description = 'Compétition de football à Toulouse - 29 avril 2026' } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/assets/logos-sans-fond/logo_sans_titre.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Archivo:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bottle: #043927;
      --bottle-light: #065c38;
      --gold: #C9A84C;
      --cream: #F5F0E8;
      --dark: #0a0a0a;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Archivo', sans-serif;
      background: var(--dark);
      color: var(--cream);
      overflow-x: hidden;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      overflow-wrap: break-word;
      word-break: break-word;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 4px;
    }
    ::-webkit-scrollbar-track {
      background: #0a0a0a;
    }
    ::-webkit-scrollbar-thumb {
      background: var(--bottle);
    }

    /* Reveal on scroll */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Button base */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 0;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      text-decoration: none;
      transition: all 0.2s ease;
      cursor: pointer;
      border: none;
      letter-spacing: 0.05em;
      font-size: clamp(0.75rem, 2vw, 0.95rem);
    }

    .btn-primary {
      background: var(--bottle);
      color: var(--cream);
      padding: 14px 32px;
    }
    .btn-primary:hover {
      background: var(--bottle-light);
      transform: translateY(-2px);
    }

    .btn-outline {
      background: transparent;
      color: var(--cream);
      padding: 13px 31px;
      border: 1px solid rgba(245, 240, 232, 0.4);
    }
    .btn-outline:hover {
      border-color: var(--cream);
      background: rgba(245, 240, 232, 0.05);
    }

    .btn-gold {
      background: var(--gold);
      color: #000;
      padding: 14px 32px;
    }
    .btn-gold:hover {
      background: #d4b05c;
      transform: translateY(-2px);
    }

    @media (max-width: 480px) {
      .btn {
        padding: 12px 20px;
        font-size: 0.8rem;
      }
    }
  </style>
</head>
<body>
  <slot />

  <script>
    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(el => {
        if (el.isIntersecting) {
          el.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
