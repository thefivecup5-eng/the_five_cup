---
---

<section class="countdown-section">
  <div class="countdown-inner">
    <div class="countdown-label reveal">
      <span class="label-line"></span>
      La Compétition Commence Dans
      <span class="label-line"></span>
    </div>

    <div class="countdown-grid reveal" id="countdown">
      <div class="count-block">
        <span class="count-val" id="days">00</span>
        <span class="count-unit">Jours</span>
      </div>
      <span class="count-colon">:</span>
      <div class="count-block">
        <span class="count-val" id="hours">00</span>
        <span class="count-unit">Heures</span>
      </div>
      <span class="count-colon">:</span>
      <div class="count-block">
        <span class="count-val" id="minutes">00</span>
        <span class="count-unit">Minutes</span>
      </div>
      <span class="count-colon">:</span>
      <div class="count-block">
        <span class="count-val" id="seconds">00</span>
        <span class="count-unit">Secondes</span>
      </div>
    </div>

    <p class="countdown-date reveal">📅 29 Avril 2026 — UrbanSoccer Toulouse Sept Deniers</p>
  </div>
</section>

<style>
  .countdown-section {
    background: var(--cream);
    padding: clamp(40px, 8vw, 80px) clamp(16px, 4vw, 40px);
    overflow: hidden;
  }

  .countdown-inner {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }

  .countdown-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(10px, 2vw, 20px);
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(0.55rem, 1.5vw, 0.75rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(4, 57, 39, 0.6);
    margin-bottom: clamp(24px, 5vw, 48px);
  }

  .label-line {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: rgba(4, 57, 39, 0.2);
  }

  .countdown-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: clamp(16px, 3vw, 32px);
    flex-wrap: nowrap;
  }

  .count-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 clamp(6px, 3vw, 28px);
    position: relative;
  }

  .count-val {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 8vw, 7rem);
    color: var(--bottle);
    line-height: 1;
    transition: transform 0.2s ease;
    min-width: 2ch;
    text-align: center;
  }

  .count-unit {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(0.5rem, 1.2vw, 0.7rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(4, 57, 39, 0.5);
    margin-top: clamp(2px, 0.5vw, 8px);
  }

  .count-colon {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(1.2rem, 5vw, 5rem);
    color: var(--bottle);
    opacity: 0.3;
    margin-bottom: 20px;
    animation: blink 1s ease infinite;
    flex-shrink: 0;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.1; }
  }

  .countdown-date {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    color: rgba(4, 57, 39, 0.6);
    letter-spacing: 0.05em;
  }

  @media (max-width: 480px) {
    .count-colon {
      margin-bottom: 12px;
    }
    .label-line {
      max-width: 30px;
    }
  }
</style>

<script>
  const targetDate = new Date('2026-04-29T09:00:00');

  function pad(n: number) {
    return String(n).padStart(2, '0');
  }

  function update() {
    const now = new Date();
    const diff = targetDate.getTime() - now.getTime();

    if (diff <= 0) {
      document.getElementById('days')!.textContent = '00';
      document.getElementById('hours')!.textContent = '00';
      document.getElementById('minutes')!.textContent = '00';
      document.getElementById('seconds')!.textContent = '00';
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    const dEl = document.getElementById('days')!;
    const hEl = document.getElementById('hours')!;
    const mEl = document.getElementById('minutes')!;
    const sEl = document.getElementById('seconds')!;

    if (dEl.textContent !== pad(days)) {
      dEl.style.transform = 'scale(1.1)';
      dEl.textContent = pad(days);
      setTimeout(() => dEl.style.transform = '', 200);
    }
    hEl.textContent = pad(hours);
    mEl.textContent = pad(minutes);

    if (sEl.textContent !== pad(seconds)) {
      sEl.style.transform = 'scale(1.1)';
      sEl.textContent = pad(seconds);
      setTimeout(() => sEl.style.transform = '', 200);
    }
  }

  update();
  setInterval(update, 1000);
</script>
