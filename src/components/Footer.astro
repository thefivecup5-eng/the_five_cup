---
const TICKET_LINK = "https://docs.google.com/forms/d/e/1FAIpQLScFuQRzO2CFAP7BWfzQZgbS5u1eVtF7u3ON7vSh_o6Rfl4WEQ/viewform";
const INSTAGRAM_LINK = "https://www.instagram.com/the_five_cup?igsh=aTN0NmFlcmc5eWVx";

const quickLinks = [
  { label: 'À propos', href: '/about' },
  { label: 'Règlement', href: '/rules' },
  { label: 'Équipes', href: '/teams' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Billetterie', href: TICKET_LINK, external: true },
];
---

<footer class="site-footer">
  <!-- Top footer -->
  <div class="footer-top">
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <img src="/assets/logos-sans-fond/logo_sans_titre.png" alt="The 5 Cup" class="footer-logo" />
      </a>
      <p class="footer-tagline">La compétition de football célébrant l'athlétisme et l'esprit élémentaire.</p>
      <!-- Instagram only -->
      <div class="footer-social">
        <a href={INSTAGRAM_LINK} target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          <span>@the_five_cup</span>
        </a>
      </div>
    </div>

    <div class="footer-links">
      <h4 class="footer-heading">Liens Rapides</h4>
      <ul class="links-list">
        {quickLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="footer-link"
              target={link.external ? '_blank' : undefined}
              rel={link.external ? 'noopener noreferrer' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-contact">
      <h4 class="footer-heading">Contact</h4>
      <div class="contact-items">
        <a href="mailto:thefivecup5@gmail.com" class="contact-item">
          <span class="contact-icon">✉</span>
          thefivecup5@gmail.com
        </a>
        <a href="tel:0634829283" class="contact-item">
          <span class="contact-icon">☎</span>
          06 34 82 92 83
        </a>
        <div class="contact-item">
          <span class="contact-icon">📍</span>
          <span>UrbanSoccer Toulouse Sept Deniers<br/>2 Rue de l'Égalité, 31200 Toulouse</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom footer -->
  <div class="footer-bottom">
    <p class="footer-copy">© 2025–2026 The 5 Cup. Tous droits réservés.</p>
    <div class="footer-legal">
      <a href="/privacy" class="legal-link">Politique de confidentialité</a>
      <a href="/terms" class="legal-link">Conditions d'utilisation</a>
      <a href="/legal" class="legal-link">Mentions légales</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #050505;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .footer-top {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 40px 60px;
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 60px;
  }

  .footer-logo {
    height: 52px;
    width: auto;
    margin-bottom: 20px;
    display: block;
  }

  .footer-tagline {
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(245, 240, 232, 0.45);
    max-width: 280px;
    margin-bottom: 28px;
  }

  .footer-social {
    display: flex;
    justify-content: flex-start;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(245, 240, 232, 0.5);
    text-decoration: none;
    font-size: 0.85rem;
    font-family: 'Archivo', sans-serif;
    padding: 8px 16px;
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.2s;
  }

  .social-link:hover {
    color: var(--cream);
    border-color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.04);
  }

  .footer-heading {
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.3);
    margin-bottom: 20px;
  }

  .links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    color: rgba(245, 240, 232, 0.6);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-link::before {
    content: '→';
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
    color: var(--gold);
    font-size: 0.8rem;
  }

  .footer-link:hover {
    color: var(--cream);
  }

  .footer-link:hover::before {
    opacity: 1;
    transform: translateX(0);
  }

  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(245, 240, 232, 0.6);
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.5;
    transition: color 0.2s;
  }

  a.contact-item:hover {
    color: var(--cream);
  }

  .contact-icon {
    flex-shrink: 0;
    font-size: 0.9rem;
    opacity: 0.5;
    margin-top: 1px;
  }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 24px 40px;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: rgba(245, 240, 232, 0.3);
  }

  .footer-legal {
    display: flex;
    gap: 20px;
  }

  .legal-link {
    font-size: 0.75rem;
    color: rgba(245, 240, 232, 0.3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-link:hover {
    color: rgba(245, 240, 232, 0.7);
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-top {
      grid-template-columns: 1fr;
      padding: 60px 24px 40px;
    }
    .footer-bottom {
      padding: 20px 24px;
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-legal {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
