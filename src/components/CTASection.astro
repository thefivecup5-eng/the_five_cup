---
const TICKET_LINK = "https://docs.google.com/forms/d/e/1FAIpQLScFuQRzO2CFAP7BWfzQZgbS5u1eVtF7u3ON7vSh_o6Rfl4WEQ/viewform";
---

<section class="cta-section">
  <div class="cta-bg-text">THE 5 CUP</div>
  <div class="cta-inner reveal">
    <span class="cta-tag">Inscriptions Ouvertes</span>
    <h2 class="cta-title">Prêts à<br/>Concourir ?</h2>
    <p class="cta-desc">Enregistrez votre équipe dès maintenant et rejoignez la compétition de football la plus intense de Toulouse.</p>
    <div class="cta-actions">
      <a href={TICKET_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-gold">
        Enregistrer votre équipe — 12€/pers
      </a>
      <a href="/competition" class="btn btn-outline">
        Règlement & Infos
      </a>
    </div>
    <p class="cta-note">📍 UrbanSoccer Toulouse — 2 Rue de l'Égalité, 31200 Toulouse</p>
  </div>
</section>

<style>
  .cta-section {
    background: var(--bottle);
    padding: 120px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(4rem, 18vw, 14rem);
    color: rgba(255,255,255,0.03);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .cta-inner {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
  }

  .cta-tag::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--gold);
  }

  .cta-title {
    font-size: clamp(2.5rem, 7vw, 6rem);
    color: var(--cream);
    line-height: 0.95;
    margin-bottom: 24px;
  }

  .cta-desc {
    font-size: clamp(0.85rem, 1.8vw, 1rem);
    color: rgba(245, 240, 232, 0.65);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-bottom: 32px;
  }

  .cta-note {
    font-size: 0.8rem;
    color: rgba(245, 240, 232, 0.4);
    letter-spacing: 0.05em;
  }

  @media (max-width: 600px) {
    .cta-section {
      padding: 80px 24px;
    }
    .cta-actions {
      flex-direction: column;
      align-items: center;
    }
    .btn {
      width: 100%;
      max-width: 320px;
    }
  }
</style>
