---
const TICKET_LINK = "https://auvencecom-my.sharepoint.com/:x:/g/personal/amine_himiche_ynov_com/IQDMe_xSW0vaSYTgAldFmqcrAby2Rb4OcKezn9nKhdTBMf0?e=UFSTil";
---

<section class="hero">
  <!-- Background image -->
  <div class="hero-bg">
    <img src="/assets/photo-1641821330397-6b66a7e092be.jpg.png" alt="" aria-hidden="true" class="hero-img" />
    <div class="hero-overlay"></div>
  </div>

  <!-- Vertical label -->
  <div class="hero-side-label">
    <span>TOULOUSE — 29.04.2026</span>
  </div>

  <!-- Main content -->
  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="eyebrow-dot"></span>
      Compétition de Football
    </div>

    <h1 class="hero-title">
      THE<br/>
      <span class="title-accent">FIVE</span><br/>
      CUP
    </h1>

    <p class="hero-desc">
      Trois poules, quinze équipes, une victoire ultime.<br/>
      Là où les éléments s'affrontent et les champions émergent.
    </p>

    <div class="hero-meta">
      <div class="meta-item">
        <span class="meta-val">29</span>
        <span class="meta-label">Avril 2026</span>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-item">
        <span class="meta-val">15</span>
        <span class="meta-label">Équipes</span>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-item">
        <span class="meta-val">90</span>
        <span class="meta-label">Joueurs</span>
      </div>
    </div>

    <div class="hero-actions">
      <a href={TICKET_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        Enregistrer votre équipe — 12€/pers
      </a>
      <a href="/competition" class="btn btn-outline">
        Voir la compétition →
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: 0 40px 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(20%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(4, 57, 39, 0.96) 0%,
      rgba(4, 57, 39, 0.6) 40%,
      rgba(0,0,0,0.3) 100%
    );
  }

  .hero-side-label {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center;
    z-index: 2;
    font-family: 'Archivo', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(245, 240, 232, 0.4);
    text-transform: uppercase;
    writing-mode: horizontal-tb;
    white-space: nowrap;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    width: 100%;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Archivo', sans-serif;
    font-size: clamp(0.65rem, 1.5vw, 0.8rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    animation: fadeUpHero 0.7s ease 0.2s both;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    background: var(--gold);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 12vw, 12rem);
    line-height: 0.88;
    color: var(--cream);
    text-transform: uppercase;
    margin-bottom: 32px;
    animation: fadeUpHero 0.7s ease 0.35s both;
  }

  .title-accent {
    color: var(--gold);
    -webkit-text-stroke: 0px;
    display: inline-block;
  }

  .hero-desc {
    font-size: clamp(0.85rem, 2vw, 1.05rem);
    line-height: 1.7;
    color: rgba(245, 240, 232, 0.7);
    margin-bottom: 36px;
    max-width: 480px;
    animation: fadeUpHero 0.7s ease 0.5s both;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: clamp(12px, 3vw, 24px);
    margin-bottom: 40px;
    animation: fadeUpHero 0.7s ease 0.6s both;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
  }

  .meta-val {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--cream);
    line-height: 1;
  }

  .meta-label {
    font-size: clamp(0.6rem, 1.2vw, 0.7rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.5);
    margin-top: 4px;
  }

  .meta-divider {
    width: 1px;
    height: 40px;
    background: rgba(245, 240, 232, 0.2);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    animation: fadeUpHero 0.7s ease 0.75s both;
  }

  .scroll-hint {
    position: absolute;
    right: 40px;
    bottom: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    z-index: 2;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(245, 240, 232, 0.5));
    animation: scrollPulse 1.5s ease infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.5; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }

  .scroll-hint span {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.4);
    writing-mode: vertical-rl;
    font-family: 'Archivo', sans-serif;
  }

  @keyframes fadeUpHero {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 0 20px 60px;
      align-items: flex-end;
    }
    .hero-title {
      font-size: clamp(3rem, 16vw, 5.5rem);
    }
    .hero-side-label,
    .scroll-hint {
      display: none;
    }
    .hero-actions {
      flex-direction: column;
    }
    .btn {
      text-align: center;
      justify-content: center;
      width: 100%;
    }
    .hero-meta {
      gap: 16px;
    }
    .meta-divider {
      height: 30px;
    }
  }
</style>
